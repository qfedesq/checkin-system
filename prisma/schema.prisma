generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  ADMIN
}

enum AccountStatus {
  PENDING_APPROVAL
  ACTIVE
  DISABLED
}

enum Category {
  DRIVER
  HELPER
}

enum LeaveType {
  VACATION
  DAY_OFF
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocType {
  DRIVER_LICENSE
  HEALTH_CARD
  OTHER
}

enum DocStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum DeliveredDocType {
  PAYSLIP
  INTERNAL_DOC
  OTHER
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(EMPLOYEE)
  status              AccountStatus        @default(PENDING_APPROVAL)
  disabledReason      DisableReason?
  mustChangePassword  Boolean              @default(false)
  deviceId            String?              @unique
  deviceApprovedAt    DateTime?
  deviceApprovedById  String?
  createdAt           DateTime             @default(now())
  approvedAt          DateTime?
  approvedById        String?
  webauthnCredentials WebAuthnCredential[]
  profile             EmployeeProfile?
  leaves              LeaveRequest[]
  documents           DocumentUpload[]
  deliveriesReceived  DeliveredDocument[]  @relation("DeliveryRecipient")
  deliveriesSent      DeliveredDocument[]  @relation("DeliverySender")
  attendances         Attendance[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  pushSubscriptions   PushSubscription[]
  profileChangeRequests ProfileChangeRequest[]
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DisableReason {
  MANUAL
  EXPIRED_LICENSE
  EXPIRED_HEALTH_CARD
  EXPIRED_FOOD_COURSE
}

model ProfileChangeRequest {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  changes      Json
  status       ChangeRequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  note         String?
  createdAt    DateTime            @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
}

model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId Bytes    @unique
  publicKey    Bytes
  counter      BigInt
  deviceName   String?
  transports   String[]
  createdAt    DateTime @default(now())
}

model EmployeeProfile {
  userId                    String    @id
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  legajo                    String?   @unique
  lastName                  String
  firstName                 String
  dob                       DateTime
  cuil                      String    @unique
  hireDate                  DateTime?
  category                  Category
  phone                     String
  professionalLicenseExpiry DateTime?
  healthCardExpiry          DateTime
  foodCourseExpiry          DateTime
  shirtSize                 String
  hoodieSize                String
  jacketSize                String
  pantsSize                 String
  shoeSize                  String
  address                   String
  addressNumber             String
  neighborhood              String
  city                      String
  postalCode                String
  signatureBlobUrl          String?
  emergencyContact          String
  emergencyPhone            String
  dni                       String?   @unique
  dniFrontBlobUrl           String?
  dniBackBlobUrl            String?
  licenseFrontBlobUrl       String?
  licenseBackBlobUrl        String?
  healthCardFrontBlobUrl    String?
  healthCardBackBlobUrl     String?
  foodCourseFrontBlobUrl    String?
  foodCourseBackBlobUrl     String?
  faceImageBlobUrl          String?
  vacationWeeksPerYear      Int       @default(2)
  notifiedLicenseExpiryAt   DateTime?
  notifiedHealthExpiryAt    DateTime?
  notifiedFoodCourseExpiryAt DateTime?
  // Geocerca de check-in: si checkinLat/Lng están seteados, el empleado sólo puede
  // fichar dentro de checkinRadiusM metros de ese punto. Sin zona seteada, se permite
  // desde cualquier lado (compatibilidad con perfiles existentes).
  checkinLat                Float?
  checkinLng                Float?
  checkinRadiusM            Int       @default(100)
  // Geocerca de check-OUT (independiente de la de check-in): el empleado puede fichar la
  // salida en un lugar distinto al de entrada. Misma semántica: sin zona = libre.
  checkoutLat               Float?
  checkoutLng               Float?
  checkoutRadiusM           Int       @default(100)
  updatedAt                 DateTime  @updatedAt
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         LeaveType
  startDate    DateTime
  endDate      DateTime
  days         Int
  status       LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  note         String?
  createdAt    DateTime    @default(now())

  @@index([startDate, endDate])
  @@index([userId])
  @@index([status])
}

model DocumentUpload {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         DocType
  blobUrl      String
  mimeType     String
  expiresAt    DateTime?
  status       DocStatus @default(PENDING_REVIEW)
  notifiedAt   DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  note         String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([status])
}

model DeliveredDocument {
  id              String           @id @default(cuid())
  recipientId     String
  recipient       User             @relation("DeliveryRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdById     String
  creator         User             @relation("DeliverySender", fields: [createdById], references: [id], onDelete: Cascade)
  type            DeliveredDocType
  title           String
  originalBlobUrl String
  signedBlobUrl   String?
  originalHash    String?
  openedAt        DateTime?
  // Dónde estampar la firma al abrir: esquina (bottom-left/bottom-right/top-left/top-right)
  // y página (1-based; null = última). Lo elige el admin al cargar el documento.
  signAnchor      String?
  signPage        Int?
  // Posición exacta de la firma (normalizada 0..1 desde arriba-izquierda de la página).
  // Si están seteadas, tienen prioridad sobre signAnchor: se estampa SÓLO la firma ahí.
  signX           Float?
  signY           Float?
  // "Visto" en la bandeja del empleado (distinto de openedAt = abierto/firmado): al entrar
  // a Recibidos se marca como visto y el contador de no leídos deja de contarlo.
  seenAt          DateTime?
  createdAt       DateTime         @default(now())

  @@index([recipientId])
}

model Attendance {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkInAt   DateTime
  checkInLat  Float
  checkInLng  Float
  checkOutAt  DateTime?
  checkOutLat Float?
  checkOutLng Float?
  durationMin Int?
  checkoutReminderSentAt DateTime?

  @@index([userId, checkInAt])
  @@index([checkOutAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  subjectId String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  userId    String?
  challenge String   @unique
  kind      String
  createdAt DateTime @default(now())
  expiresAt DateTime
}
